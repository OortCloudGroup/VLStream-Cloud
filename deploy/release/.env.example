# 默认 compose 已提供可直接启动的公开默认值；生产环境请复制为 .env 并修改密码。
TZ=Asia/Shanghai
HTTP_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MYSQL_DATABASE=blade
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=vlstream
MYSQL_PASSWORD=change-me-db
REDIS_PASSWORD=change-me-redis
MINIO_ROOT_USER=vlstream
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=vlstream

# 使用 compose.external.yaml 时填写。
EXTERNAL_MYSQL_URL=jdbc:mysql://127.0.0.1:3306/blade?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
EXTERNAL_MYSQL_USERNAME=vlstream
EXTERNAL_MYSQL_PASSWORD=change-me
EXTERNAL_REDIS_HOST=127.0.0.1
EXTERNAL_REDIS_PORT=6379
EXTERNAL_REDIS_PASSWORD=change-me
