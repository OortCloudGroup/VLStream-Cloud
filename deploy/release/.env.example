# The bundled Compose file has local defaults. Copy this file to .env and
# replace every change-me value before production use.
TZ=Asia/Shanghai
HTTP_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
WEBRTC_PORT=8000

MYSQL_DATABASE=oortcloud_workflowforms_vls
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=vlstream
MYSQL_PASSWORD=change-me-db
REDIS_PASSWORD=change-me-redis
MINIO_ROOT_USER=vlstream
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=vlstream

# WebRTC-streamer v0.8.16 publishes UDP ports 50000-50010.
# For access from another computer, set this to the Docker host's reachable
# LAN address, public address, or resolvable hostname and open that UDP range.
WEBRTC_STREAMER_IMAGE=mpromonet/webrtc-streamer:v0.8.16
WEBRTC_EXTERNAL_HOST=host.docker.internal

# Optional private integrations. Leave blank for a standalone deployment.
XXL_JOB_ADMIN_ADDRESSES=
UNIFIEDMESSAGINGSEND_URL=

# Required by compose.external.yaml.
EXTERNAL_MYSQL_URL=jdbc:mysql://127.0.0.1:3306/oortcloud_workflowforms_vls?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
EXTERNAL_MYSQL_USERNAME=vlstream
EXTERNAL_MYSQL_PASSWORD=change-me
EXTERNAL_REDIS_HOST=127.0.0.1
EXTERNAL_REDIS_PORT=6379
EXTERNAL_REDIS_PASSWORD=change-me
