<?xml version="1.0" encoding="UTF-8"?>
<ehcache updateCheck="false" dynamicConfig="false">
    <diskStore path="java.io.tmpdir"/>

    <cache name="RETRY_LIMIT_CACHE"
           maxEntriesLocalHeap="2000"
           eternal="false"
           timeToIdleSeconds="1800"
           timeToLiveSeconds="1800"
           overflowToDisk="false"
           statistics="true">
    </cache>

    <!-- Cache for half an hour -->
    <cache name="HALF_HOUR"
        maxElementsInMemory="10000"
        maxElementsOnDisk="100000"
        eternal="false"
        timeToIdleSeconds="1800"
        timeToLiveSeconds="1800"
        overflowToDisk="false"
        diskPersistent="false" />

    <!-- Cache for one hour -->
    <cache name="HOUR"
        maxElementsInMemory="10000"
        maxElementsOnDisk="100000"
        eternal="false"
        timeToIdleSeconds="3600"
        timeToLiveSeconds="3600"
        overflowToDisk="false"
        diskPersistent="false" />

    <!-- Cache for one day -->
    <cache name="ONE_DAY"
        maxElementsInMemory="10000"
        maxElementsOnDisk="100000"
        eternal="false"
        timeToIdleSeconds="86400"
        timeToLiveSeconds="86400"
        overflowToDisk="false"
        diskPersistent="false" />

    <!--
        name: Cache name.
        maxElementsInMemory: Maximum number of elements in memory.
        eternal: Whether the object is permanently valid. Once set, timeout will have no effect.
        timeToIdleSeconds: Set the allowed idle time for an object before it expires (unit: seconds). Used only when eternal=false (the object is not permanently valid), optional attribute, default value is 0, which means infinite idle time.
        timeToLiveSeconds: Set the allowed lifespan for an object before it expires (unit: seconds). The maximum time is between the creation time and expiration time. Used only when eternal=false (the object is not permanently valid), default value is 0, which means infinite lifespan.
        overflowToDisk: When the number of objects in memory reaches maxElementsInMemory, Ehcache will write the objects to disk.
        diskSpoolBufferSizeMB: This parameter sets the buffer size of the DiskStore (disk cache). The default is 30MB. Each Cache should have its own buffer.
        maxElementsOnDisk: Maximum number of cache elements on the hard disk.
        diskPersistent: Whether the disk store persists between restarts of the Virtual Machine. The default value is false.
        diskExpiryThreadIntervalSeconds: Interval for running the disk expiration thread, default is 120 seconds.
        memoryStoreEvictionPolicy: When the maxElementsInMemory limit is reached, Ehcache will clear memory based on the specified policy. The default policy is LRU (Least Recently Used). You can set it to FIFO (First In First Out) or LFU (Less Frequently Used).
        clearOnFlush: Whether to clear when memory capacity reaches maximum.
    -->
    <defaultCache name="DEFAULT_CACHE"
        maxElementsInMemory="10000"
        eternal="false"
        timeToIdleSeconds="120"
        timeToLiveSeconds="120"
        overflowToDisk="false"
        maxElementsOnDisk="100000"
        diskPersistent="false"
        diskExpiryThreadIntervalSeconds="120"
        memoryStoreEvictionPolicy="LRU"/>

</ehcache>
