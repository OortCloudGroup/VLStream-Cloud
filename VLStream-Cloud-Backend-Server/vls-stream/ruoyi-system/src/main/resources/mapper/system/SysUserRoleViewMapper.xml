<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysUserRoleViewMapper">

    <resultMap type="com.ruoyi.system.domain.SysUserRoleView" id="SysUserRoleResult">
        <result property="userId" column="user_id"/>
        <result property="roleId" column="role_id"/>
    </resultMap>
    <select id="selectUserIdsByRoleId" resultType="String">
        select u.user_id from sys_user u
        inner join sys_user_role sur
            on u.user_id = sur.user_id and sur.role_id = #{roleId}
    </select>
    <select id="selectByCondition" resultType="com.ruoyi.system.domain.SysUserRoleView">
        SELECT
        sur.user_id,
        sur.role_id,
        sur.tenant_id,
        r.role_name
        FROM sys_user_role sur
        LEFT JOIN sys_role r ON r.role_id = sur.role_id
        <where>
            <if test="userId != null and userId != ''">
                AND sur.user_id = #{userId}
            </if>
            <if test="roleId != null and roleId != ''">
                AND sur.role_id = #{roleId}
            </if>
        </where>
        LIMIT 1
    </select>

</mapper>
