<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.vlstream.test.vlstream.mapper.VlsTimeStrategyMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="vlsTimeStrategyResultMap" type="com.ruoyi.vlstream.test.vlstream.pojo.entity.TimeStrategy">
        <result column="device_id" property="deviceId"/>
        <result column="strategy_type" property="strategyType"/>
        <result column="daily_times" property="dailyTimes" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="weekly_times" property="weeklyTimes" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
    </resultMap>

    <select id="selectVlsTimeStrategyPage" resultMap="vlsTimeStrategyResultMap">
        select * from vls_time_strategy where is_deleted = 0 order by create_time desc
    </select>

    <select id="exportVlsTimeStrategy" resultType="com.ruoyi.vlstream.test.vlstream.excel.VlsTimeStrategyExcel">
        SELECT * FROM vls_time_strategy ${ew.customSqlSegment}
    </select>

</mapper>
